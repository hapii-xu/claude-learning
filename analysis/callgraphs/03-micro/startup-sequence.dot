// 微观：启动链路时序图（Graphviz DOT）
// 渲染: dot -Tpng startup-sequence.dot -o startup-sequence.png

digraph StartupSequence {
    rankdir=TB;
    fontname="Helvetica";
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=9, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=7, color="#555555"];
    bgcolor="#FAFAFA";
    pad=0.3;
    nodesep=0.3;
    ranksep=0.35;

    // ==========================================
    // 时间线行
    // ==========================================
    subgraph cluster_timeline {
        label="";
        style=invis;

        // 时间步骤
        subgraph cluster_step1 {
            label="① 进程启动";
            style="filled,rounded";
            color="#E3F2FD";
            fillcolor="#E3F2FD";
            fontcolor="#1565C0";
            fontsize=9;

            s1_cli [label="cli.tsx::main()\nprofileCheckpoint\nparseArgs", fillcolor="#BBDEFB"];
            s1_fast [label="快路径?\n--version / --dump-*\n/ daemon / remote", fillcolor="#E1F5FE"];
            s1_import [label="import('./main.tsx')", fillcolor="#BBDEFB"];
        }

        subgraph cluster_step2 {
            label="② 主启动器";
            style="filled,rounded";
            color="#E8F5E9";
            fillcolor="#E8F5E9";
            fontcolor="#2E7D32";
            fontsize=9;

            s2_main [label="main.tsx::main()\ninitializeWarningHandler\nstartCapturingEarlyInput\ninitializeEntrypoint\neagerLoadSettings", fillcolor="#C8E6C9"];
        }

        subgraph cluster_step3 {
            label="③ preAction (trust 前)";
            style="filled,rounded";
            color="#FFF3E0";
            fillcolor="#FFF3E0";
            fontcolor="#E65100";
            fontsize=9;

            s3_init [label="init.ts::init()\napplySafeEnvVars\nconfigureGlobalMTLS\nconfigureGlobalAgents\npreconnectAnthropicApi\ninitJetBrainsDetection\ndetectCurrentRepository\nsetupGracefulShutdown\nensureScratchpadDir", fillcolor="#FFE0B2"];
        }

        subgraph cluster_step4 {
            label="④ action handler";
            style="filled,rounded";
            color="#F3E5F5";
            fillcolor="#F3E5F5";
            fontcolor="#6A1B9A";
            fontsize=9;

            s4_setup [label="setup.ts::setup()\nswitchSession\nsetCwd\ncaptureHooksConfigSnapshot\ninitializeFileChangedWatcher\ncreateWorktreeForSession\ninitSessionMemory\nprefetchApiKey", fillcolor="#E1BEE7"];
            s4_caps [label="能力装配\ngetCommands()\ngetMcpToolsCommandsAndResources()\ninitBundledSkills()\ninitBuiltinPlugins()\ngetAgentDefinitionsWithOverrides()\ninitializeGrowthBook()", fillcolor="#E1BEE7"];
            s4_tele [label="initializeTelemetryAfterTrust()\n← trust 后才启动 telemetry sink", fillcolor="#F8BBD0"];
        }

        subgraph cluster_step5 {
            label="⑤ 进入 REPL";
            style="filled,rounded";
            color="#FFEBEE";
            fillcolor="#FFEBEE";
            fontcolor="#C62828";
            fontsize=9;

            s5_launch [label="replLauncher.tsx::launchRepl()\n动态 import App.tsx\n动态 import REPL.tsx\nInk 渲染循环启动", fillcolor="#FFCDD2"];
            s5_ui [label="App.tsx → REPL.tsx\nMessages + PromptInput\n全局快捷键注册\n用户可见交互式工作台", fillcolor="#FFCDD2"];
        }
    }

    // ==========================================
    // 流程边
    // ==========================================
    s1_cli -> s1_fast [label="解析参数"];
    s1_fast -> s1_import [label="未命中\n(默认路径)", color="#1565C0", penwidth=1.2];
    s1_fast -> s1_fast [label="命中\n→ exit(0)", style=dashed, color="#999"];

    s1_import -> s2_main [label="调用 main(argv)", color="#2E7D32", penwidth=1.2];

    s2_main -> s3_init [label="preAction hook", color="#E65100", penwidth=1.2];

    s3_init -> s4_setup [label="init 完成\n→ action handler", color="#6A1B9A", penwidth=1.2];

    s4_setup -> s4_caps [label="setup 完成", color="#6A1B9A"];
    s4_caps -> s4_tele [label="能力装配完成", color="#C62828"];
    s4_tele -> s4_tele [label="trust 通过后才执行", style=dashed, color="#C62828"];

    s4_tele -> s5_launch [label="showSetupScreens\n→ launchRepl()", color="#C62828", penwidth=1.2];

    s5_launch -> s5_ui [label="渲染启动", color="#C62828"];
}
